---
import Layout from '../layouts/Layout.astro';

const navItems = [
	{
		title: '博客',
		href: '/blog',
		icon: 'book',
	},
	{
		title: '项目',
		href: '/projects',
		icon: 'folder',
	},
	{
		title: '文档',
		href: '/docs',
		icon: 'file',
	},
	{
		title: '起源',
		href: '/origin',
		icon: 'info',
	},
];

const base = import.meta.env.BASE_URL;

const withBase = (path: string) => {
	const trimmedBase = base.endsWith('/') ? base.slice(0, -1) : base;
	const normalizedPath = path.startsWith('/') ? path : `/${path}`;

	return `${trimmedBase}${normalizedPath}`;
};
---

<Layout title="Dead Soul Insects" description="冷色残光中的技术记录、项目与文档整理" hideChrome={true} fullBleed={true}>
	<section class="cover-frame" aria-labelledby="cover-title">
		<div class="cover-light" aria-hidden="true">
			<span class="glow glow-left"></span>
			<span class="glow glow-right"></span>
			<span class="glow glow-bottom"></span>
		</div>

		<div class="cover-grid" aria-hidden="true"></div>

		<div class="cover-content">
			<p class="cover-kicker">DEAD SOUL INSECTS</p>

			<h1 id="cover-title" class="cover-title">Dead Soul Insects</h1>

			<p class="cover-subtitle">一个在冷色残光里，缓慢展开的个人站点</p>

			<p class="cover-description">
				收纳技术记录、实践项目与长期整理，让零散想法在暗处缓慢成形
			</p>

			<nav class="cover-nav" aria-label="首页主要入口">
				{
					navItems.map((item) => (
						<a class="cover-link" href={withBase(item.href)}>
							<span class="cover-icon" aria-hidden="true">
								{item.icon === 'book' && (
									<svg viewBox="0 0 24 24" focusable="false">
										<path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H11v16H6.5A2.5 2.5 0 0 0 4 21.5v-16Z" />
										<path d="M13 3h4.5A2.5 2.5 0 0 1 20 5.5v16a2.5 2.5 0 0 0-2.5-2.5H13V3Z" />
									</svg>
								)}
								{item.icon === 'folder' && (
									<svg viewBox="0 0 24 24" focusable="false">
										<path d="M3.5 6.5A2.5 2.5 0 0 1 6 4h4.2l1.8 2.2h6A2.5 2.5 0 0 1 20.5 8.7v8.8A2.5 2.5 0 0 1 18 20H6a2.5 2.5 0 0 1-2.5-2.5v-11Z" />
										<path d="M7.5 10h9" />
									</svg>
								)}
								{item.icon === 'file' && (
									<svg viewBox="0 0 24 24" focusable="false">
										<path d="M6 3.5h7l5 5V20a.5.5 0 0 1-.5.5h-11A.5.5 0 0 1 6 20V3.5Z" />
										<path d="M13 3.5V9h5" />
										<path d="M9 13h6" />
										<path d="M9 16.5h5" />
									</svg>
								)}
								{item.icon === 'info' && (
									<svg viewBox="0 0 24 24" focusable="false">
										<circle cx="12" cy="12" r="8.5" />
										<path d="M12 11.5v5" />
										<path d="M12 7.5h.01" />
									</svg>
								)}
							</span>
							<span>{item.title}</span>
						</a>
					))
				}
			</nav>
		</div>

		<div class="cover-motto" aria-label="站点标语">
			<p>WHERE DEAD SOULS STILL GLOW</p>
			<p>逝魂未灭，幽光犹存</p>
		</div>
	</section>
</Layout>

<style>
	:global(html) {
		margin: 0;
		min-height: 100%;
		overflow-x: hidden;
		background: #02040c;
	}

	:global(body) {
		margin: 0;
		min-height: 100%;
		overflow-x: hidden;
		background:
			radial-gradient(circle at 16% 8%, rgba(92, 73, 220, 0.16), transparent 35%),
			radial-gradient(circle at 85% 18%, rgba(76, 166, 214, 0.08), transparent 40%),
			linear-gradient(180deg, #050817 0%, #02040c 62%, #01030a 100%);
	}

	.cover-frame {
		position: relative;
		isolation: isolate;
		display: grid;
		place-items: center;
		box-sizing: border-box;
		width: 100vw;
		max-width: none;
		height: 100svh;
		min-height: 100svh;

		margin: 0;
		padding: clamp(42px, 5vw, 78px) clamp(22px, 5vw, 72px)
			clamp(88px, 8vw, 118px);

		overflow: hidden;
		text-align: center;

		border: none;
		border-radius: 0;

		background:
			radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.055), transparent 32%),
			linear-gradient(180deg, rgba(13, 18, 35, 0.72), rgba(2, 4, 12, 0.82)),
			rgba(3, 6, 18, 0.72);
		backdrop-filter: none;
		box-shadow: none;
	}

	.cover-light {
		position: absolute;
		inset: 0;
		z-index: -20;
		pointer-events: none;
		opacity: 0.48;
	}

	.glow {
		position: absolute;
		display: block;
		border-radius: 999px;
		filter: blur(68px);
	}

	.glow-left {
		top: -220px;
		left: -170px;
		width: 540px;
		height: 540px;
		background: rgba(111, 78, 218, 0.2);
	}

	.glow-right {
		top: 26px;
		right: -170px;
		width: 500px;
		height: 500px;
		background: rgba(76, 168, 214, 0.12);
	}

	.glow-bottom {
		bottom: -280px;
		left: 50%;
		width: 720px;
		height: 560px;
		background: rgba(70, 72, 176, 0.1);
		transform: translateX(-50%);
	}

	.cover-grid {
		position: absolute;
		inset: 0;
		z-index: -10;
		pointer-events: none;
		opacity: 0.055;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.7) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.7) 1px, transparent 1px);
		background-size: 72px 72px;
		mask-image: radial-gradient(circle at center, black 0%, transparent 72%);
	}

	.cover-content {
		width: min(100%, 1200px);
		min-width: 0;
	}

	.cover-kicker {
		margin: 0;
		font-size: clamp(0.78rem, 1.2vw, 0.95rem);
		font-weight: 700;
		letter-spacing: 0.34em;
		text-transform: uppercase;
		color: rgba(125, 211, 252, 0.88);
	}

	.cover-title {
		max-width: min(1200px, 100%);
		margin: 26px auto 0;
		font-size: clamp(3.9rem, 9.6vw, 9rem);
		font-weight: 900;
		line-height: 0.88;
		letter-spacing: -0.08em;
		color: #f8fafc;
		overflow-wrap: normal;
		text-wrap: balance;
		text-shadow: 0 0 34px rgba(186, 230, 253, 0.1);
	}

	.cover-subtitle {
		max-width: 900px;
		margin: clamp(24px, 3.8vw, 38px) auto 0;
		font-size: clamp(1.35rem, 2.65vw, 2.55rem);
		font-weight: 900;
		line-height: 1.08;
		letter-spacing: -0.045em;
		color: #edf2ff;
		text-wrap: balance;
	}

	.cover-description {
		max-width: 680px;
		margin: 20px auto 0;
		font-size: clamp(0.95rem, 1.2vw, 1.05rem);
		line-height: 1.75;
		color: #93a2be;
		text-wrap: balance;
	}

	.cover-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 10px;
		margin-top: 28px;
	}

	.cover-link {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 10px 17px;
		border: 1px solid rgba(148, 163, 184, 0.18);
		border-radius: 999px;
		background: rgba(15, 23, 42, 0.46);
		color: #e2e8f0;
		text-decoration: none;
		backdrop-filter: blur(14px);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
		transition:
			transform 0.22s ease,
			border-color 0.22s ease,
			background 0.22s ease,
			color 0.22s ease;
	}

	.cover-icon {
		display: inline-flex;
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		color: rgba(125, 211, 252, 0.88);
	}

	.cover-icon svg {
		width: 100%;
		height: 100%;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.9;
		stroke-linecap: round;
		stroke-linejoin: round;
		filter: drop-shadow(0 0 5px rgba(125, 211, 252, 0.12));
	}

	.cover-link span {
		font-size: 0.9rem;
		font-weight: 700;
	}

	.cover-link:hover,
	.cover-link:focus-visible {
		color: #e0f2fe;
		border-color: rgba(125, 211, 252, 0.4);
		background: rgba(45, 63, 99, 0.5);
		transform: translateY(-2px);
	}

	.cover-link:hover .cover-icon,
	.cover-link:focus-visible .cover-icon {
		color: rgba(125, 211, 252, 0.96);
	}

	.cover-link:focus-visible {
		outline: 2px solid rgba(125, 211, 252, 0.86);
		outline-offset: 4px;
	}

	.cover-motto {
		position: absolute;
		right: 24px;
		bottom: 88px;
		left: 24px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 7px;
		color: rgba(100, 116, 139, 0.82);
		pointer-events: none;
	}

	.cover-motto p {
		margin: 0;
		font-size: clamp(0.64rem, 0.9vw, 0.74rem);
		line-height: 1.3;
		letter-spacing: 0.32em;
		text-transform: uppercase;
	}

	.cover-motto p:last-child {
		font-size: clamp(0.62rem, 0.85vw, 0.72rem);
		letter-spacing: 0.2em;
		text-transform: none;
		color: rgba(71, 85, 105, 0.78);
	}

	@media (max-height: 760px) and (min-width: 821px) {
		.cover-frame {
			padding: 34px clamp(22px, 5vw, 72px) 78px;
		}

		.cover-kicker {
			font-size: 0.72rem;
			letter-spacing: 0.28em;
		}

		.cover-title {
			margin-top: 18px;
			font-size: clamp(3.4rem, 8.6vw, 7.2rem);
			line-height: 0.9;
		}

		.cover-subtitle {
			margin-top: 22px;
			font-size: clamp(1.15rem, 2.3vw, 2rem);
		}

		.cover-description {
			margin-top: 14px;
			font-size: 0.92rem;
			line-height: 1.6;
		}

		.cover-nav {
			margin-top: 20px;
		}

		.cover-link {
			padding: 8px 14px;
		}

		.cover-motto {
			bottom: 88px;
			gap: 5px;
		}
	}

	@media (max-height: 600px) and (min-width: 821px) {
		.cover-frame {
			padding-top: 26px;
			padding-bottom: 62px;
		}

		.cover-title {
			margin-top: 14px;
			font-size: clamp(3rem, 7.4vw, 5.9rem);
		}

		.cover-subtitle {
			margin-top: 18px;
			font-size: clamp(1.05rem, 2vw, 1.58rem);
		}

		.cover-description {
			display: none;
		}

		.cover-nav {
			margin-top: 18px;
		}

		.cover-motto p {
			font-size: 0.6rem;
		}
	}

	@media (max-width: 820px) {
		.cover-frame {
			width: 100vw;
			height: 100svh;
			min-height: 100svh;
			margin: 0;
			padding: 42px 18px 96px;
			border-radius: 0;
		}

		.cover-kicker {
			letter-spacing: 0.26em;
		}

		.cover-title {
			margin-top: 24px;
			font-size: clamp(3.25rem, 15.4vw, 5.6rem);
			line-height: 0.9;
			letter-spacing: -0.075em;
		}

		.cover-subtitle {
			margin-top: 26px;
			font-size: clamp(1.24rem, 6.2vw, 2.05rem);
			line-height: 1.12;
		}

		.cover-description {
			margin-top: 18px;
			font-size: 0.98rem;
			line-height: 1.7;
		}

		.cover-nav {
			gap: 10px;
			margin-top: 24px;
		}

		.cover-link {
			padding: 11px 16px;
		}

		.cover-motto {
			bottom: 88px;
		}
	}

	@media (max-width: 820px) and (max-height: 720px) {
		.cover-frame {
			padding-top: 30px;
			padding-bottom: 72px;
		}

		.cover-kicker {
			font-size: 0.68rem;
			letter-spacing: 0.22em;
		}

		.cover-title {
			margin-top: 18px;
			font-size: clamp(2.85rem, 13.8vw, 4.7rem);
		}

		.cover-subtitle {
			margin-top: 18px;
			font-size: clamp(1.08rem, 5vw, 1.55rem);
		}

		.cover-description {
			display: none;
		}

		.cover-nav {
			margin-top: 18px;
		}

		.cover-link {
			padding: 8px 14px;
		}
	}

	@media (max-width: 430px) {
		.cover-frame {
			padding-top: 34px;
		}

		.cover-title {
			font-size: clamp(2.9rem, 14.8vw, 4.1rem);
			letter-spacing: -0.06em;
		}

		.cover-nav {
			max-width: 260px;
			margin-right: auto;
			margin-left: auto;
		}

		.cover-link {
			justify-content: center;
			min-width: 92px;
		}

		.cover-motto p {
			letter-spacing: 0.16em;
		}

		.cover-motto p:last-child {
			letter-spacing: 0.12em;
		}
	}
</style>
