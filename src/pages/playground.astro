---
import Layout from '../layouts/Layout.astro';

type Star = {
	id: number;
	left: number;
	top: number;
	size: number;
	opacity: number;
	duration: number;
	delay: number;
	blur: number;
	color: string;
	driftX: number;
	driftY: number;
};

const navItems = [
	{ title: '博客', href: '/blog', icon: 'book' },
	{ title: '项目', href: '/projects', icon: 'folder' },
	{ title: '文档', href: '/docs', icon: 'file' },
	{ title: '起源', href: '/origin', icon: 'info' },
];

const base = import.meta.env.BASE_URL;

const withBase = (path: string) => {
	const trimmedBase = base.endsWith('/') ? base.slice(0, -1) : base;
	const normalizedPath = path.startsWith('/') ? path : `/${path}`;

	return `${trimmedBase}${normalizedPath}`;
};

const createSeededRandom = (seed: number) => {
	let value = seed;

	return () => {
		value = (value * 9301 + 49297) % 233280;
		return value / 233280;
	};
};

const buildStars = (): Star[] => {
	const random = createSeededRandom(20260517);
	const count = 160;
	const colorPalette = [
		'rgba(255, 255, 255, 0.94)',
		'rgba(226, 232, 240, 0.92)',
		'rgba(186, 230, 253, 0.96)',
		'rgba(191, 219, 254, 0.94)',
	];

	return Array.from({ length: count }, (_, id) => {
		const sizeSeed = random();
		const opacitySeed = random();
		const durationSeed = random();
		const delaySeed = random();
		const blurSeed = random();
		const colorSeed = random();
		const size = 1.4 + sizeSeed * 3.4;
		const opacity = 0.32 + opacitySeed * 0.58;
		const duration = 2.6 + durationSeed * 4.2;
		const delay = delaySeed * 8;
		const blur = size > 3 ? 0.8 + blurSeed * 1.8 : blurSeed * 0.8;
		const color = colorPalette[Math.floor(colorSeed * colorPalette.length)];

		return {
			id,
			left: random() * 100,
			top: random() * 100,
			size,
			opacity,
			duration,
			delay,
			blur,
			color,
			driftX: (random() - 0.5) * 12,
			driftY: (random() - 0.5) * 12,
		};
	});
};

const stars = buildStars();
---

<Layout title="Playground | Dead Soul Insects" description="Dead Soul Insects 首页星光背景实验页" hideChrome={true} fullBleed={true}>
	<section class="playground-cover" aria-labelledby="playground-title">
		<details class="control-panel" open>
			<summary>背景参数</summary>
			<div class="control-grid">
				<label>
					<span>中心冷雾</span>
					<input type="range" min="0" max="0.32" step="0.01" value="0.18" data-var="--fog-core" />
					<output>0.18</output>
				</label>
				<label>
					<span>蓝色雾光</span>
					<input type="range" min="0" max="0.22" step="0.01" value="0.11" data-var="--fog-cyan" />
					<output>0.11</output>
				</label>
				<label>
					<span>左侧紫光</span>
					<input type="range" min="0" max="0.42" step="0.01" value="0.27" data-var="--left-violet" />
					<output>0.27</output>
				</label>
				<label>
					<span>右侧蓝光</span>
					<input type="range" min="0" max="0.34" step="0.01" value="0.17" data-var="--right-blue" />
					<output>0.17</output>
				</label>
				<label>
					<span>星光强度</span>
					<input type="range" min="0.3" max="1" step="0.01" value="0.84" data-var="--starfield-opacity" />
					<output>0.84</output>
				</label>
				<label>
					<span>星光数量</span>
					<input type="range" min="40" max="160" step="1" value="160" data-stars />
					<output>160</output>
				</label>
				<label>
					<span>星点大小</span>
					<input type="range" min="0.6" max="1.8" step="0.05" value="1" data-var="--star-size-scale" />
					<output>1</output>
				</label>
				<label>
					<span>闪烁峰值</span>
					<input type="range" min="0.6" max="1.5" step="0.05" value="1" data-var="--twinkle-peak" />
					<output>1</output>
				</label>
				<label>
					<span>漂浮幅度</span>
					<input type="range" min="0" max="2" step="0.05" value="1" data-var="--drift-scale" />
					<output>1</output>
				</label>
				<label>
					<span>暗角强度</span>
					<input type="range" min="0" max="0.6" step="0.01" value="0.34" data-var="--vignette" />
					<output>0.34</output>
				</label>
				<label>
					<span>内容高度</span>
					<input type="range" min="-8" max="6" step="0.1" value="-2.6" data-var="--content-y" data-unit="vh" />
					<output>-2.6vh</output>
				</label>
				<label>
					<span>标题大小</span>
					<input type="range" min="7" max="13" step="0.1" value="10" data-var="--title-vw" data-unit="vw" />
					<output>10vw</output>
				</label>
			</div>
			<button class="control-reset" type="button" data-reset>重置参数</button>
		</details>

		<div class="cover-ambient" aria-hidden="true"></div>

		<div class="starfield" aria-hidden="true">
			{
				stars.map((star) => (
					<span
						class="star"
						style={`
							--star-x: ${star.left}%;
							--star-y: ${star.top}%;
							--star-size: ${star.size}px;
							--star-opacity: ${star.opacity};
							--star-duration: ${star.duration}s;
							--star-float-duration: ${Math.max(10, star.duration * 2.2)}s;
							--star-delay: ${star.delay}s;
							--star-blur: ${star.blur}px;
							--star-color: ${star.color};
							--star-drift-x: ${star.driftX}px;
							--star-drift-y: ${star.driftY}px;
							--star-shine: ${Math.max(5, star.size * 4)}px;
						`}
					></span>
				))
			}
		</div>

		<div class="cover-content">
			<p class="cover-kicker">DEAD SOUL INSECTS</p>
			<h1 id="playground-title" class="cover-title">Dead Soul Insects</h1>
			<p class="cover-subtitle">一个在冷色残光里，缓慢展开的个人站点</p>
			<p class="cover-description">收纳技术记录、实践项目与长期整理，让零散想法在暗处缓慢成形</p>

			<nav class="cover-nav" aria-label="首页主要入口">
				{
					navItems.map((item) => (
						<a class="cover-link" href={withBase(item.href)}>
							<span class="cover-icon" aria-hidden="true">
								{item.icon === 'book' && (
									<svg viewBox="0 0 24 24" focusable="false">
										<path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H11v16H6.5A2.5 2.5 0 0 0 4 21.5v-16Z" />
										<path d="M13 3h4.5A2.5 2.5 0 0 1 20 5.5v16a2.5 2.5 0 0 0-2.5-2.5H13V3Z" />
									</svg>
								)}
								{item.icon === 'folder' && (
									<svg viewBox="0 0 24 24" focusable="false">
										<path d="M3.5 6.5A2.5 2.5 0 0 1 6 4h4.2l1.8 2.2h6A2.5 2.5 0 0 1 20.5 8.7v8.8A2.5 2.5 0 0 1 18 20H6a2.5 2.5 0 0 1-2.5-2.5v-11Z" />
										<path d="M7.5 10h9" />
									</svg>
								)}
								{item.icon === 'file' && (
									<svg viewBox="0 0 24 24" focusable="false">
										<path d="M6 3.5h7l5 5V20a.5.5 0 0 1-.5.5h-11A.5.5 0 0 1 6 20V3.5Z" />
										<path d="M13 3.5V9h5" />
										<path d="M9 13h6" />
										<path d="M9 16.5h5" />
									</svg>
								)}
								{item.icon === 'info' && (
									<svg viewBox="0 0 24 24" focusable="false">
										<circle cx="12" cy="12" r="8.5" />
										<path d="M12 11.5v5" />
										<path d="M12 7.5h.01" />
									</svg>
								)}
							</span>
							<span>{item.title}</span>
						</a>
					))
				}
			</nav>
		</div>

		<div class="cover-motto" aria-label="站点标语">
			<p>WHERE DEAD SOULS STILL GLOW</p>
			<p>逝魂未灭，幽光犹存</p>
		</div>
	</section>
</Layout>

<script>
	const cover = document.querySelector<HTMLElement>('.playground-cover');
	const stars = Array.from(document.querySelectorAll<HTMLElement>('.star'));
	const controls = Array.from(document.querySelectorAll<HTMLInputElement>('.control-panel input'));
	const resetButton = document.querySelector<HTMLButtonElement>('[data-reset]');

	const formatValue = (input: HTMLInputElement) => `${input.value}${input.dataset.unit ?? ''}`;

	const updateOutput = (input: HTMLInputElement) => {
		const output = input.parentElement?.querySelector('output');

		if (output) {
			output.textContent = formatValue(input);
		}
	};

	const updateVisibleStars = (count: number) => {
		stars.forEach((star, index) => {
			star.style.display = index < count ? '' : 'none';
		});
	};

	const applyControl = (input: HTMLInputElement) => {
		if (input.dataset.stars !== undefined) {
			updateVisibleStars(Number(input.value));
		} else if (cover && input.dataset.var) {
			cover.style.setProperty(input.dataset.var, formatValue(input));
		}

		updateOutput(input);
	};

	controls.forEach((input) => {
		applyControl(input);
		input.addEventListener('input', () => applyControl(input));
	});

	resetButton?.addEventListener('click', () => {
		controls.forEach((input) => {
			input.value = input.defaultValue;
			applyControl(input);
		});
	});
</script>

<style>
	:global(html),
	:global(body) {
		margin: 0;
		min-height: 100%;
		overflow-x: hidden;
		background: #02040c;
	}

	.playground-cover {
		--fog-core: 0.18;
		--fog-cyan: 0.11;
		--left-violet: 0.27;
		--right-blue: 0.17;
		--starfield-opacity: 0.84;
		--star-size-scale: 1;
		--twinkle-low: 0.35;
		--twinkle-mid: 0.78;
		--twinkle-peak: 1;
		--drift-scale: 1;
		--vignette: 0.34;
		--content-y: -2.6vh;
		--title-vw: 10vw;
		--title-size: clamp(4.25rem, var(--title-vw), 9.4rem);
		position: relative;
		isolation: isolate;
		display: grid;
		place-items: center;
		box-sizing: border-box;
		width: 100vw;
		height: 100svh;
		min-height: 100svh;
		margin: 0;
		padding: clamp(38px, 5vw, 76px) clamp(22px, 5vw, 72px) clamp(86px, 8vw, 116px);
		overflow: hidden;
		text-align: center;
		background:
			radial-gradient(circle at 50% 16%, rgba(220, 235, 250, 0.045), transparent 32%),
			linear-gradient(180deg, rgba(12, 17, 33, 0.42), rgba(2, 4, 12, 0.82)),
			#02040c;
	}

	.control-panel {
		position: fixed;
		top: 14px;
		left: 14px;
		z-index: 20;
		width: min(360px, calc(100vw - 28px));
		max-height: calc(100svh - 28px);
		padding: 12px;
		border: 1px solid rgba(148, 163, 184, 0.2);
		border-radius: 20px;
		background: rgba(6, 10, 24, 0.78);
		box-shadow: 0 22px 70px rgba(0, 0, 0, 0.32);
		backdrop-filter: blur(18px);
		overflow: auto;
		color: #dbeafe;
		font-size: 0.82rem;
		text-align: left;
	}

	.control-panel summary {
		color: rgba(125, 211, 252, 0.94);
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		cursor: pointer;
		user-select: none;
	}

	.control-grid {
		display: grid;
		gap: 10px;
		margin-top: 12px;
	}

	.control-grid label {
		display: grid;
		grid-template-columns: 5.2rem 1fr 3.4rem;
		gap: 10px;
		align-items: center;
		color: rgba(203, 213, 225, 0.88);
	}

	.control-grid input {
		width: 100%;
		accent-color: #7dd3fc;
	}

	.control-grid output {
		color: rgba(186, 230, 253, 0.9);
		font-variant-numeric: tabular-nums;
		text-align: right;
	}

	.control-reset {
		width: 100%;
		margin-top: 12px;
		padding: 9px 12px;
		border: 1px solid rgba(125, 211, 252, 0.22);
		border-radius: 999px;
		background: rgba(15, 23, 42, 0.56);
		color: #e0f2fe;
		font: inherit;
		font-weight: 700;
		cursor: pointer;
	}

	.playground-cover::after {
		content: '';
		position: absolute;
		inset: 0;
		z-index: -10;
		pointer-events: none;
		background:
			radial-gradient(ellipse at center, transparent 0%, transparent 38%, rgba(0, 0, 0, var(--vignette)) 100%),
			linear-gradient(90deg, rgba(0, 0, 0, 0.22), transparent 24%, transparent 76%, rgba(0, 0, 0, 0.24));
	}

	.cover-ambient {
		position: absolute;
		inset: 0;
		z-index: -30;
		pointer-events: none;
		background:
			radial-gradient(
				ellipse at 50% 36%,
				rgba(210, 226, 245, var(--fog-core)) 0%,
				rgba(56, 189, 248, var(--fog-cyan)) 20%,
				rgba(15, 23, 42, 0.18) 44%,
				transparent 70%
			),
			radial-gradient(circle at 14% 10%, rgba(124, 58, 237, var(--left-violet)), transparent 36%),
			radial-gradient(circle at 86% 18%, rgba(56, 189, 248, var(--right-blue)), transparent 38%),
			radial-gradient(ellipse at 50% 92%, rgba(49, 46, 129, 0.16), transparent 44%),
			linear-gradient(180deg, rgba(15, 23, 42, 0.6) 0%, rgba(3, 7, 18, 0.9) 62%, rgba(2, 4, 12, 1) 100%);
	}

	.cover-ambient::before,
	.cover-ambient::after {
		content: '';
		position: absolute;
		border-radius: 999px;
		pointer-events: none;
		filter: blur(78px);
	}

	.cover-ambient::before {
		inset: 16% 22% 34%;
		background: rgba(115, 135, 190, 0.17);
		opacity: 0.7;
	}

	.cover-ambient::after {
		top: 24%;
		left: 50%;
		width: min(48vw, 760px);
		height: min(34vw, 500px);
		background: rgba(125, 211, 252, 0.11);
		opacity: 0.58;
		transform: translateX(-50%);
	}

	.starfield {
		position: absolute;
		inset: 0;
		z-index: -20;
		pointer-events: none;
		overflow: hidden;
		opacity: var(--starfield-opacity);
	}

	.star {
		position: absolute;
		left: var(--star-x);
		top: var(--star-y);
		width: calc(var(--star-size) * var(--star-size-scale));
		height: calc(var(--star-size) * var(--star-size-scale));
		animation: floatStar var(--star-float-duration) ease-in-out var(--star-delay) infinite;
	}

	.star::before {
		content: '';
		position: absolute;
		inset: 0;
		display: block;
		border-radius: 999px;
		background: var(--star-color);
		opacity: var(--star-opacity);
		filter: blur(var(--star-blur));
		box-shadow: 0 0 var(--star-shine) var(--star-color);
		animation: twinkleStar var(--star-duration) ease-in-out var(--star-delay) infinite;
	}

	.cover-content,
	.cover-motto {
		position: relative;
		z-index: 2;
	}

	.cover-content {
		width: min(100%, 1200px);
		min-width: 0;
		transform: translateY(var(--content-y));
	}

	.cover-kicker {
		margin: 0;
		font-size: clamp(0.78rem, 1.2vw, 0.95rem);
		font-weight: 700;
		letter-spacing: 0.34em;
		text-transform: uppercase;
		color: rgba(125, 211, 252, 0.9);
	}

	.cover-title {
		max-width: min(1200px, 100%);
		margin: 26px auto 0;
		font-size: var(--title-size);
		font-weight: 900;
		line-height: 0.88;
		letter-spacing: -0.08em;
		color: #f8fafc;
		text-wrap: balance;
		text-shadow: 0 0 38px rgba(186, 230, 253, 0.12);
	}

	.cover-subtitle {
		max-width: 900px;
		margin: clamp(24px, 3.8vw, 38px) auto 0;
		font-size: clamp(1.35rem, 2.65vw, 2.55rem);
		font-weight: 900;
		line-height: 1.08;
		letter-spacing: -0.045em;
		color: #edf2ff;
		text-wrap: balance;
	}

	.cover-description {
		max-width: 680px;
		margin: 20px auto 0;
		font-size: clamp(0.95rem, 1.2vw, 1.05rem);
		line-height: 1.75;
		color: #9aa8c4;
		text-wrap: balance;
	}

	.cover-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 10px;
		margin-top: 28px;
	}

	.cover-link {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 10px 17px;
		border: 1px solid rgba(148, 163, 184, 0.2);
		border-radius: 999px;
		background: rgba(15, 23, 42, 0.48);
		color: #e2e8f0;
		text-decoration: none;
		backdrop-filter: blur(14px);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.045);
		transition:
			transform 0.22s ease,
			border-color 0.22s ease,
			background 0.22s ease,
			color 0.22s ease;
	}

	.cover-icon {
		display: inline-flex;
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
		width: 18px;
		height: 18px;
		color: rgba(125, 211, 252, 0.88);
	}

	.cover-icon svg {
		width: 100%;
		height: 100%;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.9;
		stroke-linecap: round;
		stroke-linejoin: round;
		filter: drop-shadow(0 0 5px rgba(125, 211, 252, 0.12));
	}

	.cover-link span {
		font-size: 0.9rem;
		font-weight: 700;
	}

	.cover-link:hover,
	.cover-link:focus-visible {
		color: #e0f2fe;
		border-color: rgba(125, 211, 252, 0.4);
		background: rgba(45, 63, 99, 0.52);
		transform: translateY(-2px);
	}

	.cover-link:focus-visible {
		outline: 2px solid rgba(125, 211, 252, 0.86);
		outline-offset: 4px;
	}

	.cover-motto {
		position: absolute;
		right: 24px;
		bottom: 88px;
		left: 24px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 7px;
		color: rgba(100, 116, 139, 0.82);
		pointer-events: none;
	}

	.cover-motto p {
		margin: 0;
		font-size: clamp(0.64rem, 0.9vw, 0.74rem);
		line-height: 1.3;
		letter-spacing: 0.32em;
		text-transform: uppercase;
	}

	.cover-motto p:last-child {
		font-size: clamp(0.62rem, 0.85vw, 0.72rem);
		letter-spacing: 0.2em;
		text-transform: none;
		color: rgba(71, 85, 105, 0.78);
	}

	@keyframes twinkleStar {
		0%,
		100% {
			transform: scale(0.85);
			opacity: calc(var(--star-opacity) * var(--twinkle-low));
		}

		35% {
			transform: scale(1);
			opacity: calc(var(--star-opacity) * var(--twinkle-mid));
		}

		62% {
			transform: scale(1.25);
			opacity: calc(var(--star-opacity) * var(--twinkle-peak));
		}
	}

	@keyframes floatStar {
		0%,
		100% {
			transform: translate3d(0, 0, 0);
		}

		50% {
			transform: translate3d(calc(var(--star-drift-x) * var(--drift-scale)), calc(var(--star-drift-y) * var(--drift-scale)), 0);
		}
	}

	@media (max-height: 760px) and (min-width: 821px) {
		.playground-cover {
			--content-y: -2vh;
			padding: 34px clamp(22px, 5vw, 72px) 78px;
		}

		.cover-kicker {
			font-size: 0.72rem;
			letter-spacing: 0.28em;
		}

		.cover-title {
			margin-top: 18px;
			font-size: clamp(3.4rem, 8.6vw, 7.2rem);
		}

		.cover-subtitle {
			margin-top: 22px;
			font-size: clamp(1.15rem, 2.3vw, 2rem);
		}

		.cover-description {
			margin-top: 14px;
			font-size: 0.92rem;
			line-height: 1.6;
		}

		.cover-nav {
			margin-top: 20px;
		}
	}

	@media (max-height: 600px) and (min-width: 821px) {
		.cover-description {
			display: none;
		}
	}

	@media (max-width: 820px) {
		.control-panel {
			max-height: 42svh;
		}

		.playground-cover {
			--content-y: -2.4vh;
			--starfield-opacity: 0.72;
			padding: 42px 18px 96px;
		}

		.star:nth-child(n + 111) {
