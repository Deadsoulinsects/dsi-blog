---
import Layout from '../layouts/Layout.astro';

const aboutSections = [
	{
		title: '这个站是做什么的',
		description:
			'Dead Soul Insects 是一个偏安静的个人站点，用来放博客、项目入口和整理后的说明页。不追求把一切都展示出来，只保留那些愿意慢慢写清楚的内容。',
	},
	{
		title: '主要内容',
		description:
			'内容主要围绕建站记录、借助AI完成的事情、工具实践与少量仍在成形的想法。以小白的视角看待遇到的问题，为和我一样的人提供解决问题的思路。',
	},
];

const contacts = [
	{
		type: 'email',
		label: '邮箱',
		value: '3178381848@qq.com',
		copyValue: '3178381848@qq.com',
		icon: '/icons/email.svg',
	},
	{
		type: 'qq',
		label: 'QQ',
		value: '3178381848',
		copyValue: '3178381848',
		icon: '/icons/qq.svg',
	},
	{
		type: 'wechat',
		label: '微信',
		value: 'ky3178381848',
		copyValue: 'ky3178381848',
		icon: '/icons/wechat.svg',
	},
];

---

<Layout title="关于 | Dead Soul Insects" description="Dead Soul Insects 的简要站点介绍与写作方向说明。" canonicalPath="/about/">
	<section class="page-card">
		<header class="page-intro">
			<p class="kicker">关于</p>
			<h1>突发奇想创建的个人站。</h1>
			<p class="lead">
				这里不是完整履历，也不是社交主页。它更像一个安静的公开出口，把愿意留下的文字、项目与说明整理出来。
			</p>
		</header>

		<section class="summary-block" aria-labelledby="about-summary-title">
			<h2 id="about-summary-title">这一页的边界</h2>
			<p>
				这里只保留必要的站点说明，不展开过多私人信息。重心放在内容本身，也让这个页面保持简洁。
			</p>
		</section>

		<div class="section-grid" aria-label="关于页面内容分组">
			{
				aboutSections.map((section) => (
					<section class="content-card">
						<h2>{section.title}</h2>
						<p>{section.description}</p>
					</section>
				))
			}
		</div>

		<section class="contact-card" aria-labelledby="contact-title">
			<h2 id="contact-title">联系方式</h2>
			<ul class="contact-list">
				{
					contacts.map((contact) => (
						<li class="contact-item">
							<div class="contact-main">
								<span class="contact-icon" aria-hidden="true">
									<img src={contact.icon} alt="" loading="lazy" />
								</span>
								<div class="contact-text">
									<span class="contact-label">{contact.label}</span>
									<span class="contact-value">{contact.value}</span>
								</div>
							</div>
							<button class="copy-btn" type="button" data-copy-value={contact.copyValue}>
								<img src="/icons/copy.svg" alt="" aria-hidden="true" />
								<span>复制</span>
							</button>
						</li>
					))
				}
			</ul>
		</section>
	</section>
</Layout>

<script>
	const copyButtons = document.querySelectorAll<HTMLButtonElement>('.copy-btn');

	copyButtons.forEach((button) => {
		button.addEventListener('click', async () => {
			const copyValue = button.dataset.copyValue;

			if (!copyValue) {
				return;
			}

			await navigator.clipboard.writeText(copyValue);
			const label = button.querySelector('span');

			if (label) {
				label.textContent = '已复制';
			}

			button.classList.add('copied');

			window.setTimeout(() => {
				if (label) {
					label.textContent = '复制';
				}

				button.classList.remove('copied');
			}, 1200);
		});
	});
</script>

<style>
	.page-card {
		padding: 32px;
		border: 1px solid var(--line);
		border-radius: var(--radius-panel);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
			var(--panel);
		backdrop-filter: var(--glass-blur);
		box-shadow: var(--shadow);
	}

	.page-intro {
		max-width: 46rem;
	}

	.summary-block {
		box-sizing: border-box;
		width: 100%;
		max-width: none;
	}

	.summary-block,
	.content-card,
	.contact-card {
		padding: 24px;
		border: 1px solid var(--line);
		border-radius: var(--radius-card);
	}

	.summary-block {
		background: var(--panel-strong);
	}

	.summary-block {
		margin: 0 0 20px;
	}

	.kicker {
		margin: 0 0 12px;
		font-size: 0.88rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent-soft);
	}

	h1,
	h2,
	p {
		margin-top: 0;
	}

	h1 {
		margin-bottom: 18px;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1.1;
	}

	h2 {
		margin-bottom: 12px;
		font-size: clamp(1.2rem, 2.4vw, 1.6rem);
		line-height: 1.25;
	}

	h1,
	h2,
	p {
		overflow-wrap: anywhere;
	}

	p {
		margin-bottom: 0;
		line-height: 1.8;
		color: var(--text-soft);
	}

	.lead {
		margin-bottom: 28px;
		font-size: 1.02rem;
		color: var(--text-soft);
	}

	.section-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: 28px;
		width: 100%;
		max-width: none;
	}

	.content-card {
		box-sizing: border-box;
		min-width: 0;
		width: auto;
		background:
			radial-gradient(circle at top right, rgba(110, 195, 255, 0.08), transparent 34%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
			var(--panel);
	}

	.contact-card {
		box-sizing: border-box;
		margin-top: 28px;
		background:
			radial-gradient(circle at top right, rgba(157, 140, 255, 0.1), transparent 34%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
			var(--panel);
	}

	.contact-list {
		display: grid;
		gap: 14px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.contact-item {
		display: flex;
		gap: 16px;
		align-items: center;
		justify-content: space-between;
		padding: 16px;
		border: 1px solid rgba(153, 176, 255, 0.14);
		border-radius: 18px;
		background: rgba(8, 10, 18, 0.35);
		color: var(--text-soft);
		line-height: 1.6;
	}

	.contact-main {
		display: flex;
		gap: 14px;
		align-items: center;
		min-width: 0;
	}

	.contact-icon {
		display: inline-flex;
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border: 1px solid rgba(153, 210, 255, 0.38);
		border-radius: 16px;
		background:
			radial-gradient(circle at 32% 18%, rgba(178, 225, 255, 0.34), transparent 58%),
			linear-gradient(135deg, rgba(110, 195, 255, 0.2), rgba(157, 140, 255, 0.16)),
			rgba(14, 27, 48, 0.82);
		box-shadow:
			0 0 18px rgba(110, 195, 255, 0.12),
			0 10px 24px rgba(0, 0, 0, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.14);
		color: var(--accent-soft);
	}

	.contact-icon img {
		width: 22px;
		height: 22px;
		filter: brightness(1.22) contrast(1.08) drop-shadow(0 0 5px rgba(110, 195, 255, 0.18));
	}

	.contact-text {
		display: grid;
		gap: 2px;
		min-width: 0;
	}

	.contact-label {
		color: var(--accent-soft);
		font-size: 0.86rem;
		font-weight: 700;
	}

	.contact-value {
		color: var(--text);
		overflow-wrap: anywhere;
	}

	.copy-btn {
		display: inline-flex;
		flex: 0 0 auto;
		gap: 7px;
		align-items: center;
		justify-content: center;
		padding: 9px 14px;
		border: 1px solid rgba(153, 210, 255, 0.38);
		border-radius: var(--radius-pill);
		background:
			radial-gradient(circle at 24% 18%, rgba(178, 225, 255, 0.28), transparent 58%),
			linear-gradient(135deg, rgba(110, 195, 255, 0.2), rgba(157, 140, 255, 0.16)),
			rgba(14, 27, 48, 0.82);
		box-shadow:
			0 0 18px rgba(110, 195, 255, 0.1),
			0 10px 24px rgba(0, 0, 0, 0.16),
			inset 0 1px 0 rgba(255, 255, 255, 0.12);
		color: var(--text);
		font: inherit;
		font-size: 0.9rem;
		font-weight: 700;
		cursor: pointer;
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.copy-btn img {
		width: 16px;
		height: 16px;
		filter: brightness(1.18) contrast(1.08) drop-shadow(0 0 4px rgba(110, 195, 255, 0.16));
	}

	.copy-btn:hover,
	.copy-btn:focus-visible {
		transform: translateY(-1px);
		border-color: rgba(178, 225, 255, 0.5);
		background:
			radial-gradient(circle at 24% 18%, rgba(178, 225, 255, 0.34), transparent 58%),
			linear-gradient(135deg, rgba(110, 195, 255, 0.24), rgba(157, 140, 255, 0.2)),
			rgba(14, 27, 48, 0.9);
		box-shadow:
			0 0 22px rgba(110, 195, 255, 0.14),
			0 12px 26px rgba(0, 0, 0, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.16);
		color: #f3f6ff;
	}

	.copy-btn:focus-visible {
		outline: var(--focus-ring);
		outline-offset: var(--focus-offset);
	}

	.copy-btn.copied {
		border-color: rgba(178, 225, 255, 0.56);
		background:
			radial-gradient(circle at 24% 18%, rgba(178, 225, 255, 0.36), transparent 58%),
			linear-gradient(135deg, rgba(110, 195, 255, 0.28), rgba(157, 140, 255, 0.2)),
			rgba(14, 27, 48, 0.92);
		box-shadow:
			0 0 24px rgba(110, 195, 255, 0.16),
			0 12px 26px rgba(0, 0, 0, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.18);
		color: #f3f6ff;
	}

	@media (max-width: 900px) {
		.section-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.page-card,
		.summary-block,
		.content-card,
		.contact-card {
			padding: 24px;
		}

		.lead {
			margin-bottom: 24px;
		}

		.contact-item {
			align-items: stretch;
			flex-direction: column;
		}

		.copy-btn {
			width: 100%;
		}
	}
</style>
