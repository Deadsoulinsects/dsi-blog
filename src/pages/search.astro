---
import Layout from '../layouts/Layout.astro';
import { getSortedDocs, getSortedPosts } from '../utils/content';
import { withBase } from '../utils/paths';

const base = import.meta.env.BASE_URL;
const posts = await getSortedPosts();
const docs = await getSortedDocs();

const searchItems = [
	...posts.map((post) => ({
		type: '博客',
		title: post.data.title,
		description: post.data.description,
		href: withBase(base, `/blog/${post.id}/`),
		keywords: [post.data.title, post.data.description, ...post.data.tags].join(' '),
	})),
	...docs.map((doc) => ({
		type: '文档',
		title: doc.data.title,
		description: doc.data.description,
		href: withBase(base, `/docs/${doc.id}/`),
		keywords: [doc.data.title, doc.data.description, doc.data.category, ...doc.data.tags].join(' '),
	})),
];
---

<Layout title="搜索 | Dead Soul Insects" description="在 Dead Soul Insects 中快速筛选博客与文档内容。" canonicalPath="/search/">
	<section class="page-card intro-card">
		<p class="kicker">搜索</p>
		<h1>快速筛选站内内容</h1>
		<p>输入关键词后，页面会在本地实时筛选博客和文档，不需要额外服务。</p>
		<input id="search-input" class="search-input" type="search" placeholder="例如：Astro、Obsidian、建站、指南" />
	</section>

	<section class="results-grid" id="search-results" aria-label="搜索结果列表">
		{searchItems.map((item) => (
			<a class="result-card" href={item.href} data-search-item data-keywords={item.keywords.toLowerCase()}>
				<div class="result-meta">
					<span>{item.type}</span>
				</div>
				<h2>{item.title}</h2>
				<p>{item.description}</p>
			</a>
		))}
	</section>

	<p class="empty-state" id="search-empty" hidden>没有找到匹配内容，可以尝试更短的关键词，或者先从标签、分类、归档继续浏览。</p>
</Layout>

<script>
	const searchInput = document.querySelector<HTMLInputElement>('#search-input');
	const searchItems = Array.from(document.querySelectorAll<HTMLElement>('[data-search-item]'));
	const emptyState = document.querySelector<HTMLElement>('#search-empty');

	const applySearch = () => {
		const query = (searchInput?.value ?? '').trim().toLowerCase();
		let visibleCount = 0;

		searchItems.forEach((item) => {
			const keywords = item.dataset.keywords ?? '';
			const isVisible = query.length === 0 || keywords.includes(query);

			item.hidden = !isVisible;

			if (isVisible) {
				visibleCount += 1;
			}
		});

		if (emptyState) {
			emptyState.hidden = visibleCount > 0;
		}
	};

	searchInput?.addEventListener('input', applySearch);
</script>

<style>
	.page-card,
	.result-card {
		border: 1px solid var(--line);
		border-radius: 28px;
		backdrop-filter: blur(18px);
		box-shadow: var(--shadow);
	}

	.page-card {
		padding: 32px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
			var(--panel);
	}

	.intro-card {
		margin-bottom: 22px;
	}

	.kicker {
		margin: 0 0 12px;
		font-size: 0.88rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent-soft);
	}

	h1,
	h2,
	p {
		margin-top: 0;
	}

	h1 {
		margin-bottom: 16px;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1.08;
	}

	p {
		color: var(--text-soft);
		line-height: 1.8;
	}

	.search-input {
		width: 100%;
		margin-top: 18px;
		padding: 14px 16px;
		border: 1px solid rgba(153, 176, 255, 0.2);
		border-radius: 18px;
		background: rgba(8, 12, 24, 0.7);
		color: var(--text);
		font: inherit;
		box-sizing: border-box;
	}

	.results-grid {
		display: grid;
		gap: 18px;
	}

	.result-card {
		display: grid;
		gap: 12px;
		padding: 24px;
		background:
			radial-gradient(circle at top right, rgba(110, 195, 255, 0.1), transparent 34%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
			var(--panel);
		color: inherit;
		text-decoration: none;
	}

	.result-meta span {
		display: inline-flex;
		padding: 6px 10px;
		border-radius: 999px;
		background: rgba(110, 195, 255, 0.08);
		color: var(--accent-soft);
		font-size: 0.84rem;
	}

	.empty-state {
		margin-top: 18px;
	}
</style>
