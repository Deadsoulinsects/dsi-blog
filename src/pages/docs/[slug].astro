---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { render } from 'astro:content';
import { formatDate, formatDateTime, getSortedDocs } from '../../utils/content';
import { withBase } from '../../utils/paths';

export async function getStaticPaths() {
	const docs = await getSortedDocs();

	return docs.map((doc, index) => ({
		params: { slug: doc.id },
		props: {
			doc,
			prevDoc: docs[index - 1] ?? null,
			nextDoc: docs[index + 1] ?? null,
		},
	}));
}

const { doc, prevDoc, nextDoc } = Astro.props;
const { Content, headings } = await render(doc);
const dateLabel = formatDate(doc.data.pubDate);
const dateTime = formatDateTime(doc.data.pubDate);
const base = import.meta.env.BASE_URL;
---

<ArticleLayout
	title={doc.data.title}
	description={doc.data.description}
	sectionLabel="文档"
	backHref={withBase(base, '/docs')}
	backLabel="返回文档列表"
	dateLabel={dateLabel}
	dateTime={dateTime}
	tags={doc.data.tags}
	headings={headings}
	canonicalPath={`/docs/${doc.id}/`}
	publishedTime={doc.data.pubDate.toISOString()}
	prevLink={prevDoc ? { href: withBase(base, `/docs/${prevDoc.id}/`), label: prevDoc.data.title } : undefined}
	nextLink={nextDoc ? { href: withBase(base, `/docs/${nextDoc.id}/`), label: nextDoc.data.title } : undefined}
>
	<Content />
</ArticleLayout>
