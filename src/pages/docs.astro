---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const docs = (await getCollection('docs')).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const formatDate = (date: Date) =>
	date.toLocaleDateString('zh-CN', {
		year: 'numeric',
		month: 'long',
		day: 'numeric',
		timeZone: 'UTC',
	});

const formatDateTime = (date: Date) =>
	`${date.getUTCFullYear()}-${String(date.getUTCMonth() + 1).padStart(2, '0')}-${String(date.getUTCDate()).padStart(2, '0')}`;

const base = import.meta.env.BASE_URL;

const withBase = (path: string) => {
	const trimmedBase = base.endsWith('/') ? base.slice(0, -1) : base;
	const normalizedPath = path.startsWith('/') ? path : `/${path}`;

	return `${trimmedBase}${normalizedPath}`;
};
---

<Layout title="文档 | Dead Soul Insects" description="Dead Soul Insects 的文档列表页，整理分享文档、学习资料与配置说明。">
	<section class="page-card intro-card">
		<header class="page-intro">
			<p class="kicker">文档</p>
			<h1>把零散记录收紧成可复用的说明</h1>
			<p class="lead">
				博客偏向持续写下来的过程，文档页更偏向整理后的结果。这里直接列出当前可读的说明页，方便查阅，也方便在需要时重新打开。
			</p>
		</header>
	</section>

	<section class="doc-list" aria-label="文档列表">
		{
			docs.map((doc) => (
				<a class="doc-card" href={withBase(`/docs/${doc.id}/`)}>
					<div class="doc-card-top">
						<time class="doc-date" datetime={formatDateTime(doc.data.pubDate)}>{formatDate(doc.data.pubDate)}</time>
					</div>
					<div class="doc-card-body">
						<h2>{doc.data.title}</h2>
						<p class="doc-description">{doc.data.description}</p>
					</div>
					<span class="doc-link">打开文档 →</span>
				</a>
			))
		}
	</section>
</Layout>

<style>
	.page-card,
	.doc-card {
		border: 1px solid var(--line);
		border-radius: 28px;
		backdrop-filter: blur(18px);
		box-shadow: var(--shadow);
	}

	.page-card {
		padding: 32px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
			var(--panel);
	}

	.intro-card {
		margin-bottom: 22px;
	}

	.page-intro {
		max-width: none;
	}

	.kicker {
		margin: 0 0 12px;
		font-size: 0.88rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent-soft);
	}

	h1,
	p {
		margin-top: 0;
	}

	h1 {
		margin-bottom: 18px;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1.1;
	}

	p {
		margin-bottom: 0;
		line-height: 1.8;
		color: var(--text-soft);
		overflow-wrap: anywhere;
	}

	.lead {
		margin-bottom: 0;
		font-size: 1.02rem;
	}

	.doc-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		align-items: stretch;
	}

	.doc-card {
		position: relative;
		display: grid;
		grid-template-rows: auto 1fr auto;
		gap: 20px;
		height: 100%;
		padding: 24px;
		background:
			radial-gradient(circle at top right, rgba(110, 195, 255, 0.1), transparent 34%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
			var(--panel);
		box-sizing: border-box;
		text-decoration: none;
		transition:
			transform 0.2s ease,
			border-color 0.2s ease,
			background 0.2s ease,
			box-shadow 0.2s ease;
	}

	.doc-card-body {
		display: grid;
		align-content: start;
		gap: 12px;
	}

	.doc-card:hover,
	.doc-card:focus-visible {
		transform: translateY(-2px);
		border-color: rgba(157, 140, 255, 0.3);
		background:
			radial-gradient(circle at top right, rgba(110, 195, 255, 0.14), transparent 36%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0)),
			var(--panel-strong);
		box-shadow: 0 28px 90px rgba(0, 0, 0, 0.3);
	}

	.doc-card:focus-visible {
		outline: 2px solid rgba(110, 195, 255, 0.9);
		outline-offset: 3px;
	}

	.doc-date {
		margin: 0;
		font-size: 0.9rem;
		color: var(--accent-soft);
	}

	.doc-description {
		max-width: 34rem;
	}

	.doc-link {
		display: inline-flex;
		align-items: center;
		align-self: flex-start;
		padding: 8px 12px;
		border: 1px solid rgba(153, 176, 255, 0.18);
		border-radius: 999px;
		background: rgba(153, 176, 255, 0.08);
		color: var(--text);
		font-size: 0.95rem;
		font-weight: 600;
		line-height: 1.2;
		transition:
			border-color 0.2s ease,
			background 0.2s ease,
			color 0.2s ease;
	}

	.doc-card:hover .doc-link,
	.doc-card:focus-visible .doc-link {
		border-color: rgba(157, 140, 255, 0.28);
		background: rgba(157, 140, 255, 0.14);
		color: #f3f6ff;
	}

	@media (max-width: 900px) {
		.doc-list {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.page-card,
		.doc-card {
			padding: 24px;
		}

		.doc-card {
			gap: 18px;
		}

		.lead {
			margin-bottom: 24px;
		}
	}
</style>
