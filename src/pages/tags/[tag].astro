---
import Layout from '../../layouts/Layout.astro';
import { formatDate, formatDateTime, getAllBlogTags, getSortedPosts } from '../../utils/content';
import { toParamSlug, withBase } from '../../utils/paths';

export async function getStaticPaths() {
	const tags = await getAllBlogTags();

	return tags.map((tag) => ({
		params: { tag: tag.slug },
		props: { tagName: tag.name },
	}));
}

const { tagName } = Astro.props;
const posts = (await getSortedPosts()).filter((post) => post.data.tags.some((tag) => toParamSlug(tag) === toParamSlug(tagName)));
const base = import.meta.env.BASE_URL;
---

<Layout title={`${tagName} | 标签 | Dead Soul Insects`} description={`按标签查看 ${tagName} 相关文章。`} canonicalPath={`/tags/${toParamSlug(tagName)}/`}>
	<section class="page-card intro-card">
		<p class="kicker">标签</p>
		<h1>{tagName}</h1>
		<p>这里收纳带有该标签的博客文章。</p>
	</section>

	<section class="item-list" aria-label="标签文章列表">
		{posts.map((post) => (
			<a class="item-card" href={withBase(base, `/blog/${post.id}/`)}>
				<time datetime={formatDateTime(post.data.pubDate)}>{formatDate(post.data.pubDate)}</time>
				<h2>{post.data.title}</h2>
				<p>{post.data.description}</p>
			</a>
		))}
	</section>
</Layout>

<style>
	.page-card,
	.item-card {
		border: 1px solid var(--line);
		border-radius: 28px;
		backdrop-filter: blur(18px);
		box-shadow: var(--shadow);
	}

	.page-card {
		padding: 32px;
		margin-bottom: 22px;
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
			var(--panel);
	}

	.kicker {
		margin: 0 0 12px;
		font-size: 0.88rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent-soft);
	}

	h1,
	h2,
	p,
	time {
		margin-top: 0;
		overflow-wrap: anywhere;
	}

	h1 {
		margin-bottom: 16px;
		font-size: clamp(2rem, 4vw, 3rem);
	}

	h2 {
		margin: 0;
		font-size: clamp(1.3rem, 2.4vw, 1.65rem);
	}

	p,
	time {
		color: var(--text-soft);
		line-height: 1.8;
	}

	.item-list {
		display: grid;
		gap: 18px;
	}

	.item-card {
		display: grid;
		gap: 12px;
		padding: 24px;
		background:
			radial-gradient(circle at top right, rgba(110, 195, 255, 0.1), transparent 34%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
			var(--panel);
		color: inherit;
		text-decoration: none;
	}
</style>
