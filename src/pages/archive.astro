---
import Layout from '../layouts/Layout.astro';
import { formatDate, formatDateTime, getArchiveGroups } from '../utils/content';
import { withBase } from '../utils/paths';

const groups = await getArchiveGroups();
const base = import.meta.env.BASE_URL;
---

<Layout title="归档 | Dead Soul Insects" description="按时间查看 Dead Soul Insects 的博客文章归档。" canonicalPath="/archive/">
	<section class="page-card intro-card">
		<p class="kicker">归档</p>
		<h1>按时间回看留下来的记录</h1>
		<p>这里按年份整理博客文章，方便快速查找早期记录和后续更新。</p>
	</section>

	<div class="archive-stack" aria-label="文章归档列表">
		{groups.map((group) => (
			<section class="archive-group">
				<h2>{group.year}</h2>
				<ul>
					{group.items.map((post) => (
						<li>
							<time datetime={formatDateTime(post.data.pubDate)}>{formatDate(post.data.pubDate)}</time>
							<a href={withBase(base, `/blog/${post.id}/`)}>{post.data.title}</a>
						</li>
					))}
				</ul>
			</section>
		))}
	</div>
</Layout>

<style>
	.page-card,
	.archive-group {
		padding: 32px;
		border: 1px solid var(--line);
		border-radius: var(--radius-panel);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
			var(--panel);
		backdrop-filter: var(--glass-blur);
		box-shadow: var(--shadow);
	}

	.intro-card {
		margin-bottom: 22px;
	}

	.archive-stack {
		display: grid;
		gap: 18px;
	}

	.kicker {
		margin: 0 0 12px;
		font-size: 0.88rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent-soft);
	}

	h1,
	h2,
	p,
	ul {
		margin-top: 0;
	}

	h1 {
		margin-bottom: 18px;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1.1;
	}

	h2 {
		margin-bottom: 14px;
		font-size: clamp(1.35rem, 2.8vw, 1.9rem);
	}

	p,
	li,
	a {
		overflow-wrap: anywhere;
	}

	p,
	li,
	time {
		color: var(--text-soft);
		line-height: 1.8;
	}

	ul {
		margin-bottom: 0;
		padding: 0;
		list-style: none;
	}

	li {
		display: grid;
		grid-template-columns: minmax(8rem, auto) minmax(0, 1fr);
		gap: 16px;
		padding: 12px 0;
		border-top: 1px solid rgba(153, 176, 255, 0.1);
	}

	li:first-child {
		border-top: 0;
		padding-top: 0;
	}

	a {
		color: var(--text);
		text-decoration: none;
	}

	a:hover,
	a:focus-visible {
		color: var(--accent-soft);
	}

	@media (max-width: 640px) {
		.page-card,
		.archive-group {
			padding: 24px;
		}

		li {
			grid-template-columns: 1fr;
			gap: 6px;
		}
	}
</style>
