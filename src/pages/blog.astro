---
import Layout from '../layouts/Layout.astro';
import { formatDate, formatDateTime, getAllBlogTags, getSortedPosts } from '../utils/content';
import { withBase } from '../utils/paths';
import { getTopicGroups } from '../utils/topics';

const posts = await getSortedPosts();
const tags = await getAllBlogTags();
const topicGroups = getTopicGroups(posts);
const standalonePosts = posts.filter((post) => post.data.topic.trim() === '');
const base = import.meta.env.BASE_URL;
---

<Layout title="博客 | Dead Soul Insects" description="Dead Soul Insects 的博客列表页。" canonicalPath="/blog/">
	<section class="page-card intro-card">
		<p class="kicker">博客</p>
		<h1>持续写下来的记录。</h1>
		<p>
			这里收纳 Dead Soul Insects 的文章记录。内容以技术、建站、工具实践与阶段性思考为主，按时间安静展开。
		</p>
		{tags.length > 0 && (
			<ul class="tag-entry-list" aria-label="博客标签入口">
				{tags.map((tag) => (
					<li>
						<a href={withBase(base, `/tags/${tag.slug}/`)}>
							<span>{tag.name}</span>
							<span>{tag.count}</span>
						</a>
					</li>
				))}
			</ul>
		)}
	</section>

	{topicGroups.length > 0 && (
		<section class="topic-section" aria-label="内容专题">
			<div class="section-heading">
				<div>
					<p class="kicker">专题</p>
				</div>
				<p class="section-note">按主题整理的文章入口。</p>
			</div>

			<div class="topic-grid">
				{topicGroups.map((topicGroup) => (
					<a class="topic-card" href={withBase(base, `/blog/topics/${topicGroup.slug}/`)}>
						<div class="topic-main">
							<h2>{topicGroup.name}</h2>
							<span class="topic-count">{topicGroup.posts.length} 篇文章</span>
						</div>
					</a>
				))}
			</div>
		</section>
	)}

	<section class="post-list" aria-label="文章列表">
		{
			standalonePosts.map((post) => (
				<a class="post-card" href={withBase(base, `/blog/${post.id}/`)}>
					<div class="post-card-top">
						<time class="post-date" datetime={formatDateTime(post.data.pubDate)}>{formatDate(post.data.pubDate)}</time>
						{post.data.tags.length > 0 && (
							<ul class="tag-list" aria-label="文章标签">
								{post.data.tags.map((tag) => (
									<li>{tag}</li>
								))}
							</ul>
						)}
					</div>
					<div class="post-card-body">
						<h2>{post.data.title}</h2>
						<p class="post-description">{post.data.description}</p>
					</div>
				</a>
			))
		}
	</section>
</Layout>

<style>
	.page-card {
		padding: 32px;
		border: 1px solid var(--line);
		border-radius: var(--radius-panel);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
			var(--panel);
		backdrop-filter: var(--glass-blur);
		box-shadow: var(--shadow);
	}

	.intro-card {
		margin-bottom: 22px;
	}

	.kicker {
		margin: 0 0 12px;
		font-size: 0.88rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent-soft);
	}

	h1 {
		margin: 0 0 16px;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1.08;
	}

	h2 {
		margin: 0;
		font-size: clamp(1.3rem, 2.4vw, 1.65rem);
		line-height: 1.25;
		overflow-wrap: anywhere;
	}

	h3 {
		margin: 0;
		font-size: clamp(1.3rem, 2.3vw, 1.6rem);
		line-height: 1.25;
		overflow-wrap: anywhere;
	}

	p {
		margin: 0;
		line-height: 1.8;
		color: var(--text-soft);
	}

	.tag-entry-list {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin: 18px 0 0;
		padding: 0;
		list-style: none;
	}

	.tag-entry-list a {
		display: inline-flex;
		gap: 8px;
		align-items: center;
		padding: 7px 12px;
		border: 1px solid rgba(110, 195, 255, 0.18);
		border-radius: var(--radius-pill);
		background: var(--tag-bg);
		color: var(--text);
		text-decoration: none;
		transition:
			border-color 0.2s ease,
			background 0.2s ease,
			transform 0.2s ease;
	}

	.tag-entry-list a:hover,
	.tag-entry-list a:focus-visible {
		transform: translateY(-1px);
		border-color: var(--hover-border);
		background: rgba(157, 140, 255, 0.14);
	}

	.topic-section {
		margin-bottom: 22px;
	}

	.section-heading {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 18px;
		margin-bottom: 14px;
	}

	.section-note {
		max-width: 30rem;
		line-height: 1.7;
		text-align: right;
	}

	.topic-grid {
		display: grid;
		grid-template-columns: 1fr;
		align-items: start;
		gap: 18px;
	}

	.topic-card {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 22px;
		align-items: center;
		padding: 24px 28px;
		border: 1px solid var(--line);
		border-radius: var(--radius-panel);
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0)),
			var(--panel);
		box-shadow: 0 24px 80px rgba(0, 0, 0, 0.26);
		color: inherit;
		text-decoration: none;
		overflow: hidden;
		transition:
			transform 0.22s ease,
			border-color 0.22s ease,
			background 0.22s ease;
	}

	.topic-card::before {
		content: "";
		position: absolute;
		inset: -80% -10% auto auto;
		width: 22rem;
		height: 22rem;
		border-radius: var(--radius-pill);
		background: radial-gradient(circle, rgba(110, 195, 255, 0.14), transparent 68%);
		pointer-events: none;
	}

	.topic-main {
		position: relative;
		z-index: 1;
		display: contents;
	}

	.topic-card h2 {
		font-size: clamp(1.45rem, 3vw, 2.2rem);
		line-height: 1.05;
		letter-spacing: -0.04em;
	}

	.topic-card:hover,
	.topic-card:focus-visible {
		transform: translateY(-2px);
		border-color: rgba(157, 140, 255, 0.34);
		background:
			radial-gradient(circle at top right, rgba(110, 195, 255, 0.12), transparent 36%),
			var(--panel-strong);
	}

	.topic-card:focus-visible {
		outline: var(--focus-ring);
		outline-offset: var(--focus-offset);
	}

	.topic-count {
		display: inline-flex;
		position: relative;
		z-index: 1;
		justify-self: end;
		padding: 6px 10px;
		border: 1px solid var(--tag-border);
		border-radius: var(--radius-pill);
		background: var(--tag-bg);
		color: var(--accent-soft);
		font-size: 0.82rem;
	}

	.post-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		align-items: stretch;
	}

	.post-card {
		position: relative;
		display: grid;
		grid-template-rows: auto 1fr;
		gap: 20px;
		height: 100%;
		padding: 24px;
		border: 1px solid var(--line);
		border-radius: var(--radius-card);
		background:
			radial-gradient(circle at top right, rgba(110, 195, 255, 0.1), transparent 34%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
			var(--panel);
		backdrop-filter: var(--glass-blur);
		box-shadow: var(--shadow-soft);
		box-sizing: border-box;
		text-decoration: none;
		transition:
			transform 0.2s ease,
			border-color 0.2s ease,
			background 0.2s ease,
			box-shadow 0.2s ease;
	}

	.post-card-top,
	.tag-list {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 10px;
	}

	.post-card-body {
		display: grid;
		align-content: start;
		gap: 12px;
	}

	.post-card:hover {
		transform: translateY(-2px);
		border-color: var(--hover-border);
		background:
			radial-gradient(circle at top right, rgba(110, 195, 255, 0.14), transparent 36%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0)),
			var(--panel-strong);
		box-shadow: var(--shadow-hover);
	}

	.post-card:focus-visible {
		transform: translateY(-2px);
		border-color: var(--hover-border);
		background:
			radial-gradient(circle at top right, rgba(110, 195, 255, 0.14), transparent 36%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0)),
			var(--panel-strong);
		box-shadow: var(--shadow-hover);
		outline: var(--focus-ring);
		outline-offset: var(--focus-offset);
	}

	.post-date {
		margin: 0;
		font-size: 0.9rem;
		color: var(--accent-soft);
	}

	.post-description {
		max-width: 34rem;
		overflow-wrap: anywhere;
	}

	.tag-list {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.tag-list li {
		padding: 6px 10px;
		border: 1px solid var(--tag-border);
		border-radius: var(--radius-pill);
		background: var(--tag-bg);
		color: var(--text);
		font-size: 0.82rem;
		line-height: 1.2;
		overflow-wrap: anywhere;
	}

	@media (max-width: 900px) {
		.topic-grid,
		.post-list {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.section-heading {
			display: grid;
			align-items: start;
		}

		.section-note {
			text-align: left;
		}

		.page-card,
		.topic-card,
		.post-card {
			padding: 24px;
		}

		.topic-card {
			grid-template-columns: 1fr;
			gap: 16px;
		}

		.topic-count {
			justify-self: start;
		}

		.post-card {
			gap: 18px;
		}
	}
</style>
