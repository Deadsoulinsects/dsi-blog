---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Dead Soul Insects',
	description = '在灵魂残光中，记录技术、项目与碎片。',
} = Astro.props;

const navItems = [
	{ href: '/blog', label: '博客' },
	{ href: '/projects', label: '项目' },
	{ href: '/docs', label: '文档' },
	{ href: '/origin', label: '起源' },
	{ href: '/about', label: '关于' },
];

const normalizePath = (path: string) => {
	if (path === '/') {
		return '/';
	}

	return path.replace(/\/+$/, '');
};

const currentPath = normalizePath(Astro.url.pathname);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="site-shell">
			<div class="site-glow site-glow-left"></div>
			<div class="site-glow site-glow-right"></div>

			<header class="site-header">
				<a class="brand" href="/">
					<span class="brand-name">Dead Soul Insects</span>
					<span class="brand-tag">个人博客 / 笔记 / 项目</span>
				</a>

				<nav class="site-nav" aria-label="主导航">
					{
						navItems.map((item) => {
							const isActive = currentPath === normalizePath(item.href);

							return (
								<a class:list={{ active: isActive }} aria-current={isActive ? 'page' : undefined} href={item.href}>
									{item.label}
								</a>
							);
						})
					}
				</nav>
			</header>

			<main class="page-content">
				<slot />
			</main>

			<footer class="site-footer">
				<p>Where Dead Souls Still Glow</p>
			</footer>
		</div>
	</body>
</html>

<style>
	:root {
		color-scheme: dark;
		--bg: #070811;
		--bg-soft: rgba(20, 24, 40, 0.78);
		--panel: rgba(18, 23, 37, 0.78);
		--panel-strong: rgba(24, 31, 51, 0.92);
		--line: rgba(153, 176, 255, 0.16);
		--text: #edf2ff;
		--text-soft: #a4b0d3;
		--accent: #9d8cff;
		--accent-soft: #6ec3ff;
		--shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
	}

	html {
		background:
			radial-gradient(circle at top left, rgba(114, 92, 255, 0.18), transparent 30%),
			radial-gradient(circle at top right, rgba(52, 132, 255, 0.15), transparent 28%),
			linear-gradient(180deg, #080a12 0%, #05060d 100%);
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	body {
		font-family: Inter, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
		color: var(--text);
	}

	a {
		color: inherit;
	}

	.site-shell {
		position: relative;
		min-height: 100vh;
		max-width: 1120px;
		margin: 0 auto;
		padding: 24px 20px 40px;
		box-sizing: border-box;
	}

	.site-glow {
		position: fixed;
		width: 18rem;
		height: 18rem;
		border-radius: 999px;
		filter: blur(70px);
		opacity: 0.38;
		pointer-events: none;
		z-index: 0;
	}

	.site-glow-left {
		top: 3rem;
		left: -2rem;
		background: rgba(108, 88, 255, 0.35);
	}

	.site-glow-right {
		right: -3rem;
		bottom: 6rem;
		background: rgba(78, 186, 255, 0.22);
	}

	.site-header,
	.page-content,
	.site-footer {
		position: relative;
		z-index: 1;
	}

	.site-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 20px;
		padding: 18px 20px;
		border: 1px solid var(--line);
		border-radius: 24px;
		background: var(--bg-soft);
		backdrop-filter: blur(18px);
		box-shadow: var(--shadow);
	}

	.brand {
		display: flex;
		flex-direction: column;
		gap: 4px;
		text-decoration: none;
	}

	.brand-name {
		font-size: 1.05rem;
		font-weight: 700;
		letter-spacing: 0.06em;
	}

	.brand-tag {
		font-size: 0.88rem;
		color: var(--text-soft);
	}

	.site-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 10px;
	}

	.site-nav a {
		padding: 10px 14px;
		border: 1px solid transparent;
		border-radius: 999px;
		text-decoration: none;
		color: var(--text-soft);
		transition:
			border-color 0.2s ease,
			background 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.site-nav a:hover,
	.site-nav a:focus-visible,
	.site-nav a.active {
		color: var(--text);
		border-color: rgba(157, 140, 255, 0.3);
		background: rgba(157, 140, 255, 0.12);
		transform: translateY(-1px);
	}

	.site-nav a:focus-visible,
	.brand:focus-visible {
		outline: 2px solid rgba(110, 195, 255, 0.9);
		outline-offset: 3px;
	}

	.page-content {
		padding: 28px 0 20px;
	}

	.site-footer {
		padding-top: 8px;
		color: var(--text-soft);
		font-size: 0.88rem;
		text-align: center;
	}

	@media (max-width: 720px) {
		.site-shell {
			padding: 16px 14px 32px;
		}

		.site-header {
			align-items: flex-start;
			flex-direction: column;
		}

		.site-nav {
			justify-content: flex-start;
		}
	}
</style>
